generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(cuid())
  name               String?
  email              String?         @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  stripeCustomerId   String?         @unique
  subscriptionStatus String?         @default("free")
  subscriptionPlan   String?         @default("free")

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  feedback      FeedbackReport[]
  usageLimits   UsageLimit[]
  subscriptions Subscription[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Project {
  id              String            @id @default(cuid())
  userId          String
  title           String
  field           String
  degreeLevel     String
  language        String
  researchQuestion String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentSections DocumentSection[]
  feedbackReports FeedbackReport[]
  referencePapers ReferencePaper[]
}

model ReferencePaper {
  id             String   @id @default(cuid())
  projectId      String
  originalName   String
  mimeType       String
  sizeBytes      Int
  extractedText  String
  createdAt      DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model DocumentSection {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  sectionType String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbackReports FeedbackReport[]
}

model FeedbackReport {
  id          String    @id @default(cuid())
  projectId   String
  sectionId   String?
  userId      String
  inputText   String
  reportJson  Json
  summary     String
  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section     DocumentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLimit {
  id            String   @id @default(cuid())
  userId        String
  month         String
  aiReviewsUsed Int      @default(0)
  aiReviewsLimit Int     @default(3)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String   @unique
  status               String
  plan                 String
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
